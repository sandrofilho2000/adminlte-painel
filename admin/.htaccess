Options -MultiViews

DirectoryIndex layout.php

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /adminlte-painel/admin/

  # Preserva arquivos reais: CSS, JS, imagens, downloads e endpoints diretos.
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # A pagina e resolvida pelo caminho original em REQUEST_URI.
  RewriteRule ^$ layout.php [L,QSA]

  # Nao envia a rota pela query string.
  RewriteRule ^(.+?)/?$ layout.php [L,QSA]
</IfModule>
